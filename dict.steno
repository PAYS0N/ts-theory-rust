class Graph<T> {
	private adj = new Map<T, T[]>();

	addVertex(v: T): void {
		if (!this.adj.has(v)) this.adj.set(v, []);
	}

	addEdge(u: T, v: T, directed = false): void {
		this.addVertex(u);
		this.addVertex(v);
		this.adj.get(u)!.push(v);
		if (!directed) this.adj.get(v)!.push(u);
	}

	neighbors(v: T): T[] {
		return this.adj.get(v) ?? [];
	}

	bfs(start: T): T[] {
		const visited = new Set<T>([start]);
		const queue: T[] = [start];
		const order: T[] = [];
		let qi = 0;
		while (qi < queue.length) {
			const v = queue[qi++];
			order.push(v);
			for (const next of this.neighbors(v)) {
				if (!visited.has(next)) {
					visited.add(next);
					queue.push(next);
				}
			}
		}
		return order;
	}
}
````
